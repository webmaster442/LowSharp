<UserControl
    x:Class="LowSharp.Lowering.LoweringView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:common="clr-namespace:LowSharp.Common"
    xmlns:controls="clr-namespace:LowSharp.Common.Controls"
    xmlns:converters="clr-namespace:LowSharp.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:LowSharp.Lowering"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="720"
    d:DesignWidth="1280"
    mc:Ignorable="d">
    <UserControl.InputBindings>
        <KeyBinding
            Key="O"
            Command="{Binding OpenCodeCommand}"
            Modifiers="Ctrl" />
        <KeyBinding
            Key="F5"
            Command="{Binding LowerCommand}" />
    </UserControl.InputBindings>
    <Grid IsEnabled="{Binding IsBusy, Converter={converters:NegateConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition MinWidth="300" />
        </Grid.ColumnDefinitions>
        <Grid
            Grid.Row="0"
            Grid.ColumnSpan="3"
            Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="5,0"
                VerticalAlignment="Center"
                Text="Language:" />

            <controls:EnumComboBox
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Enum="{Binding InputLanguages}" />

            <TextBlock
                Grid.Column="2"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Text="Configuration:" />

            <controls:EnumComboBox
                Grid.Column="3"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Enum="{Binding Optimizations}" />

            <CheckBox
                Grid.Column="5"
                Margin="8,0,0,0"
                Content="Show Line numbers"
                IsChecked="{Binding ShowLineNumbers.IsChecked}" />

            <CheckBox
                Grid.Column="6"
                Margin="8,0,0,0"
                Content="Word Wrap"
                IsChecked="{Binding WordWrap.IsChecked}" />

            <TextBlock
                Grid.Column="7"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Text="Output:" />

            <controls:EnumComboBox
                Grid.Column="8"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Enum="{Binding OutputTypes}" />

            <Button
                Grid.Column="9"
                Height="30"
                MinWidth="80"
                Margin="8,0,0,0"
                Command="{Binding PreviewCommand}"
                Content="Preview">
                <Button.IsEnabled>
                    <MultiBinding Converter="{converters:AndConverter}">
                        <Binding
                            Converter="{converters:NegateConverter}"
                            Path="IsBusy" />
                        <Binding Path="IsValidLowering" />
                        <Binding
                            Converter="{local:PreviewSupportedConverter}"
                            Path="OutputTypes.SelectedValue" />
                    </MultiBinding>
                </Button.IsEnabled>
            </Button>

            <Button
                Grid.Column="10"
                Height="30"
                MinWidth="80"
                Margin="8,0,0,0"
                Command="{Binding LowerCommand}"
                Content="Lower (F5)"
                IsEnabled="{Binding IsBusy, Converter={converters:NegateConverter}}"
                Style="{DynamicResource AccentButtonStyle}" />
        </Grid>

        <avalonEdit:TextEditor
            x:Name="Input"
            Grid.Row="1"
            Grid.Column="0"
            FontFamily="Cascadia Code"
            FontSize="{DynamicResource EditorFontSize}"
            ShowLineNumbers="{Binding ShowLineNumbers.IsChecked}"
            SyntaxHighlighting="{Binding InputLanguages.SelectedValue, Converter={local:SelectedInputLanguageToHighlightingConverter}}"
            WordWrap="{Binding WordWrap.IsChecked}">
            <i:Interaction.Behaviors>
                <common:AvalonEditBehaviour BindedText="{Binding InputCode, Mode=TwoWay}" />
            </i:Interaction.Behaviors>
        </avalonEdit:TextEditor>

        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,0,30,0"
            HorizontalAlignment="Right"
            FontSize="18"
            Style="{StaticResource Watwermark}"
            Text="Input" />

        <GridSplitter
            Grid.Row="1"
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{StaticResource SolidBackgroundFillColorBaseBrush}" />

        <avalonEdit:TextEditor
            x:Name="Output"
            Grid.Row="1"
            Grid.Column="2"
            FontFamily="Cascadia Code"
            FontSize="{DynamicResource EditorFontSize}"
            IsReadOnly="True"
            ShowLineNumbers="{Binding ShowLineNumbers.IsChecked}"
            SyntaxHighlighting="{Binding OutputTypes.SelectedValue, Converter={local:SelectedOutputTypeToHighlightingConverter}}"
            WordWrap="{Binding WordWrap.IsChecked}">
            <i:Interaction.Behaviors>
                <common:AvalonEditBehaviour BindedText="{Binding OutputCode}" />
            </i:Interaction.Behaviors>
        </avalonEdit:TextEditor>

        <TextBlock
            Grid.Row="1"
            Grid.Column="2"
            Margin="0,0,30,0"
            HorizontalAlignment="Right"
            FontSize="18"
            Style="{StaticResource Watwermark}"
            Text="Output" />

    </Grid>
</UserControl>

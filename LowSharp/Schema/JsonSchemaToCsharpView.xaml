<UserControl
    x:Class="LowSharp.Schema.JsonSchemaToCsharpView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:common="clr-namespace:LowSharp.Common"
    xmlns:controls="clr-namespace:LowSharp.Common.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:LowSharp.Schema"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition
                Width="Auto"
                MinWidth="200" />
            <ColumnDefinition MinWidth="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition MinWidth="300" />
        </Grid.ColumnDefinitions>
        <GroupBox
            Grid.Column="0"
            Header="Options">
            <StackPanel>
                <TextBlock
                    Margin="8"
                    Text="DateTime type:" />
                <controls:EnumComboBox
                    Margin="8,0"
                    Enum="{Binding DateTimeTypes}" />
                <TextBlock
                    Margin="8"
                    Text="Date type:" />
                <controls:EnumComboBox
                    Margin="8,0"
                    Enum="{Binding DateTypes}" />
                <TextBlock
                    Margin="8"
                    Text="Time type:" />
                <controls:EnumComboBox
                    Margin="8,0"
                    Enum="{Binding TimeTypes}" />
                <TextBlock
                    Margin="8"
                    Text="Class style:" />
                <controls:EnumComboBox
                    Margin="8,0"
                    Enum="{Binding ClassStyles}" />
                <TextBlock
                    Margin="8"
                    Text="Json Libary:" />
                <controls:EnumComboBox
                    Margin="8,0"
                    Enum="{Binding JsonLibaries}" />
                <TextBlock
                    Margin="8"
                    Text="Access modifier:" />
                <controls:EnumComboBox
                    Margin="8,0"
                    Enum="{Binding Accesmodifers}" />
                <CheckBox
                    Margin="8"
                    Content="Use requred"
                    IsChecked="{Binding UseRequired}" />
                <CheckBox
                    Margin="8,0"
                    Content="Use nullable"
                    IsChecked="{Binding UseNullableReferenceTypes}" />
                <TextBlock
                    Margin="8"
                    Text="Namespace:" />
                <TextBox
                    Margin="8,0"
                    Text="{Binding Namespace, UpdateSourceTrigger=PropertyChanged}" />

                <Button
                    Width="170"
                    Height="35"
                    Margin="8"
                    Command="{Binding ResetCommand}"
                    Content="Reset settings" />
                <Button
                    Width="170"
                    Height="35"
                    Margin="8,0"
                    Command="{Binding GenerateCommand}"
                    Content="Generate" />
            </StackPanel>
        </GroupBox>

        <avalon:TextEditor
            Grid.Column="1"
            FontFamily="Cascadia Code"
            FontSize="{DynamicResource EditorFontSize}"
            ShowLineNumbers="{Binding ShowLineNumbers.IsChecked}"
            SyntaxHighlighting="{common:SyntaxHighlightingProvider Language=JsonNext}"
            WordWrap="{Binding WordWrap.IsChecked}">
            <i:Interaction.Behaviors>
                <common:AvalonEditBehaviour BindedText="{Binding Json, Mode=TwoWay}" />
            </i:Interaction.Behaviors>
        </avalon:TextEditor>

        <TextBlock
            Grid.Column="1"
            Margin="0,0,30,0"
            HorizontalAlignment="Right"
            FontSize="18"
            Style="{StaticResource Watwermark}"
            Text="Json" />


        <GridSplitter
            Grid.Column="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{StaticResource SolidBackgroundFillColorBaseBrush}" />

        <avalon:TextEditor
            Grid.Column="3"
            FontFamily="Cascadia Code"
            FontSize="{DynamicResource EditorFontSize}"
            IsReadOnly="True"
            ShowLineNumbers="{Binding ShowLineNumbers.IsChecked}"
            SyntaxHighlighting="{common:SyntaxHighlightingProvider Language=CsharpNext}"
            WordWrap="{Binding WordWrap.IsChecked}">
            <i:Interaction.Behaviors>
                <common:AvalonEditBehaviour BindedText="{Binding CsharpCode, Mode=TwoWay}" />
            </i:Interaction.Behaviors>
        </avalon:TextEditor>

        <TextBlock
            Grid.Column="3"
            Margin="0,0,30,0"
            HorizontalAlignment="Right"
            FontSize="18"
            Style="{StaticResource Watwermark}"
            Text="Generated Code" />

    </Grid>
</UserControl>

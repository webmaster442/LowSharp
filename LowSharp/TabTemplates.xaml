<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:LowSharp.Shell"
    xmlns:lowering="clr-namespace:LowSharp.Lowering"
    xmlns:schema="clr-namespace:LowSharp.Schema"
    xmlns:regex="clr-namespace:LowSharp.RegexTesting">

    <DataTemplate DataType="{x:Type shell:StartPageViewModel}">
        <shell:StartPage/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type regex:RegexTestingViewModel}">
        <regex:RegexTestingView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type lowering:LoweringViewModel}">
        <lowering:LoweringView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type schema:JsonSchemaToCsharpViewModel}">
        <schema:JsonSchemaToCsharpView/>
    </DataTemplate>

</ResourceDictionary>
<Window
    x:Class="LowSharp.Common.Dialogs.MessageDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LowSharp.Common.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MessageDialog"
    Width="800"
    Height="400"
    BorderBrush="{StaticResource SurfaceStrokeColorDefaultBrush}"
    BorderThickness="1"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    SnapsToDevicePixels="True"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid MinWidth="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            x:Name="TbTitle"
            Grid.Row="0"
            Margin="16,32,0,24"
            Style="{StaticResource TitleTextBlockStyle}"
            Text="Title" />
        <TextBlock
            x:Name="TbMessage"
            Grid.Row="1"
            Margin="16,0,0,0"
            Background="Transparent" />
        <Border
            Grid.Row="2"
            Background="{DynamicResource SubtleFillColorTransparentBrush}">
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    x:Name="BtnOk"
                    Width="100"
                    Margin="0,24,16,24"
                    HorizontalAlignment="Right"
                    Click="BtnOk_Click"
                    Content="Ok"
                    Style="{DynamicResource AccentButtonStyle}" />
                <Button
                    x:Name="BtnCancel"
                    Width="100"
                    Margin="8,24,16,24"
                    Click="BtnCancel_Click"
                    Content="Cancel" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
